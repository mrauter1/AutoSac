# Required web settings
APP_BASE_URL=http://localhost:8000
APP_SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://triage:triage@localhost:5432/triage

# Required Codex settings
CODEX_BIN=codex
# Optional when Codex CLI is already authenticated in this runtime.
# Leave empty to rely on Codex CLI login instead of API-key auth.
CODEX_API_KEY=

# Workspace and upload paths
# REPO_MOUNT_DIR and MANUALS_MOUNT_DIR must already exist before running bootstrap checks.
UPLOADS_DIR=/opt/triage/data/uploads
TRIAGE_WORKSPACE_DIR=/opt/triage/triage_workspace
REPO_MOUNT_DIR=/opt/triage/triage_workspace/app
MANUALS_MOUNT_DIR=/opt/triage/triage_workspace/manuals

# Optional Codex and worker tuning
# Leave CODEX_MODEL empty to use the Codex CLI default model selection.
CODEX_MODEL=
CODEX_TIMEOUT_SECONDS=3600
WORKER_POLL_SECONDS=10
WORKER_HEARTBEAT_SECONDS=60
AI_RUN_STALE_TIMEOUT_SECONDS=300
AI_RUN_MAX_RECOVERY_ATTEMPTS=3

# AI action thresholds
AUTO_SUPPORT_REPLY_MIN_CONFIDENCE=0.85
AUTO_CONFIRM_INTENT_MIN_CONFIDENCE=0.90

# Attachment limits
MAX_IMAGES_PER_MESSAGE=3
MAX_IMAGE_BYTES=5242880

# Session lifetime controls
SESSION_DEFAULT_HOURS=12
SESSION_REMEMBER_DAYS=30

# UI locale fallback when there is no locale cookie or matching Accept-Language header
UI_DEFAULT_LOCALE=en

# Phase 1 Slack outbound notification rollout
# Ship the migration and event recording with SLACK_ENABLED=false first.
SLACK_ENABLED=false
SLACK_DEFAULT_TARGET_NAME=ops_primary
SLACK_TARGETS_JSON={"ops_primary":{"enabled":false,"webhook_url":"https://hooks.slack.com/services/REPLACE/THIS/WEBHOOK"}}
SLACK_NOTIFY_TICKET_CREATED=false
SLACK_NOTIFY_PUBLIC_MESSAGE_ADDED=false
SLACK_NOTIFY_STATUS_CHANGED=false
SLACK_MESSAGE_PREVIEW_MAX_CHARS=200
SLACK_HTTP_TIMEOUT_SECONDS=10
SLACK_DELIVERY_BATCH_SIZE=10
SLACK_DELIVERY_MAX_ATTEMPTS=5
SLACK_DELIVERY_STALE_LOCK_SECONDS=120
